<?xml version="1.0" encoding="utf-8" ?>
<manifest>
  <control namespace="WorkTime" constructor="WorkTimeSplitGrid" version="1.20.1" display-name-key="WorkTimeSplitGrid_Display" description-key="WorkTimeSplitGrid_Desc" control-type="standard">
    <!-- Bound dataset: the Rounded Time Entries shown as the master list -->
    <data-set name="entries" display-name-key="entries_Display" description-key="entries_Desc"></data-set>

    <!-- Field-override properties are intentionally DISABLED: the SST defaults
         (in schema.ts) fit this deployment, so they don't need to clutter the
         maker UI. To re-expose any override, uncomment the matching <property>
         here AND its read in index.ts (resolveFieldConfig{...}). Defaults:
         totalField=sst_duration, dateField=sst_date, typeField=sst_type,
         pauseValue=Pause, completedField=sst_worksubtypecompleted,
         subtypeField=sst_workordersubtype.
    <property name="totalField" display-name-key="totalField_Display" description-key="totalField_Desc" of-type="SingleLine.Text" usage="input" required="false" />
    <property name="dateField" display-name-key="dateField_Display" description-key="dateField_Desc" of-type="SingleLine.Text" usage="input" required="false" />
    <property name="typeField" display-name-key="typeField_Display" description-key="typeField_Desc" of-type="SingleLine.Text" usage="input" required="false" />
    <property name="pauseValue" display-name-key="pauseValue_Display" description-key="pauseValue_Desc" of-type="SingleLine.Text" usage="input" required="false" />
    <property name="completedField" display-name-key="completedField_Display" description-key="completedField_Desc" of-type="SingleLine.Text" usage="input" required="false" />
    <property name="subtypeField" display-name-key="subtypeField_Display" description-key="subtypeField_Desc" of-type="SingleLine.Text" usage="input" required="false" />
    -->

    <!-- "show" (or true/yes/ja/1/on/ein) → display the AI suggestion (★) button in
         the split detail. Empty/anything else → hidden. Default: hidden. -->
    <property name="showSuggestButton" display-name-key="showSuggestButton_Display" description-key="showSuggestButton_Desc" of-type="SingleLine.Text" usage="input" required="false" />

    <resources>
      <code path="index.ts" order="1"/>
      <css path="css/WorkTimeSplitGrid.css" order="1" />
      <resx path="strings/WorkTimeSplitGrid.1033.resx" version="1.0.0" />
    </resources>

    <!-- required="false": a control whose required feature is unavailable (e.g.
         WebAPI offline) is NOT rendered by the host at all — which hid the React
         offline notice behind a generic "control can't load" error. With optional
         features the control loads everywhere; offline it shows its own notice
         and skips the (guarded) WebAPI calls. -->
    <feature-usage>
      <uses-feature name="WebAPI" required="false" />
      <uses-feature name="Utility" required="false" />
    </feature-usage>
  </control>
</manifest>
